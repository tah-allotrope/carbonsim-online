{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventCard",
  "type": "object",
  "required": ["card_id", "title", "description", "category", "effect_type", "effect_params", "prerequisites", "weight"],
  "properties": {
    "card_id": {
      "type": "string",
      "pattern": "^(crisis|opportunity|policy|market)_[0-9]{3}$",
      "description": "Unique card identifier with category prefix"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "description": "Short display title"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "Narrative text shown to the player"
    },
    "category": {
      "type": "string",
      "enum": ["crisis", "opportunity", "policy", "market"],
      "description": "Card category for visual grouping and filtering"
    },
    "effect_type": {
      "type": "string",
      "enum": [
        "emissions_spike", "allowance_withdrawal", "cost_shock",
        "offset_supply_change", "tech_unlock", "fdi_proposal",
        "cbam_threat", "election_pressure", "allowance_boost",
        "cash_boost", "none"
      ],
      "description": "Maps to an engine action or shock type"
    },
    "effect_params": {
      "type": "object",
      "description": "Parameters passed to the effect dispatcher"
    },
    "prerequisites": {
      "type": "object",
      "properties": {
        "min_year": { "type": "integer", "minimum": 1 },
        "max_year": { "type": "integer", "minimum": 1 },
        "min_cash": { "type": "number", "minimum": 0 },
        "max_penalties": { "type": "integer", "minimum": 0 }
      },
      "description": "Conditions that must be met for the card to be drawable"
    },
    "weight": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 100,
      "description": "Relative draw probability (higher = more likely)"
    },
    "choices": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "label", "description"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string", "maxLength": 40 },
          "description": { "type": "string", "maxLength": 200 },
          "effect_type": {
            "type": "string",
            "enum": [
              "emissions_spike", "allowance_withdrawal", "cost_shock",
              "offset_supply_change", "tech_unlock", "fdi_proposal",
              "cbam_threat", "election_pressure", "allowance_boost",
              "cash_boost", "none"
            ]
          },
          "effect_params": { "type": "object" }
        }
      },
      "description": "Optional player choices with different outcomes"
    }
  }
}
