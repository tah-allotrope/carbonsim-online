# CarbonSim Online - Environment Configuration
# Copy this to .env and customize for your deployment.

# Admin password for the oTree admin interface
OTREE_ADMIN_PASSWORD=changeme-use-a-strong-password

# Secret key for session security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme-generate-a-unique-secret-key

# Production mode flag
OTREE_PRODUCTION=1

# Server port (default: 8000)
OTREE_PORT=8000

# Database: use DATABASE_URL for Postgres in production.
# For local development, oTree defaults to SQLite.
# DATABASE_URL=postgres://carbonsim:carbonsim_local@db:5432/carbonsim

# Postgres settings (used by docker-compose)
POSTGRES_DB=carbonsim
POSTGRES_USER=carbonsim
POSTGRES_PASSWORD=carbonsim_local
POSTGRES_PORT=5432