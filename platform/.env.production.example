# CarbonSim production environment
# Copy to .env on the host and fill in real secrets.

OTREE_ADMIN_PASSWORD=
SECRET_KEY=
OTREE_PRODUCTION=1

# Public web port for local Docker exposure.
OTREE_PORT=8000

# Database connection for the app.
DATABASE_URL=postgres://carbonsim:replace-me@db:5432/carbonsim

# Backing Postgres container values.
POSTGRES_DB=carbonsim
POSTGRES_USER=carbonsim
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
